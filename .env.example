# OpenRouter API-Key – kostenlos erhältlich unter https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Hauptmodell: starkes multimodales Vision-Modell für Bildanalyse
OPENROUTER_PRIMARY_MODEL=google/gemini-2.5-flash

# Fallback-Modell, falls das Hauptmodell nicht verfügbar / überlastet ist
OPENROUTER_FALLBACK_MODEL=google/gemma-4-26b-a4b-it:free

# Modell für reine Text-Aufgaben (Rezeptvorschläge ohne Bild)
OPENROUTER_TEXT_MODEL=openai/gpt-4o-mini

# Optionale Angaben für OpenRouter-Ranking (siehe https://openrouter.ai/docs)
OPENROUTER_SITE_URL=http://localhost:3000
OPENROUTER_SITE_NAME=Forma

# Öffentliche Basis-URL der App. Wird für Supabase Auth-Redirects (E-Mail-
# Bestätigung) benötigt. Lokal: http://localhost:3000. In Produktion: die
# echte Domain (z. B. https://forma-app.netlify.app), OHNE abschließenden Slash.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# AI-Coach: Claude Sonnet primär, Gemini Flash und kostenloses Nemotron als Fallback
OPENROUTER_COACH_MODEL=anthropic/claude-3.5-sonnet
OPENROUTER_COACH_FREE_MODEL=nvidia/nemotron-nano-9b-v2:free

# Supabase (Cloud-Sync für Profil & Account) – Projekt unter https://supabase.com erstellen,
# supabase/schema.sql im SQL-Editor ausführen, Werte dann unter
# "Project Settings -> API" kopieren.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
